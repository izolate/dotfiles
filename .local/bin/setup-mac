#!/usr/bin/env bash

set -euo pipefail

readonly BREW_PACKAGES=(
  neovim
  ripgrep
  jq
  tree
  fd
  go
  nodejs
)

readonly GO_TOOLS=(
  golang.org/x/tools/gopls@latest
  honnef.co/go/tools/cmd/staticcheck@latest
  golang.org/x/tools/cmd/goimports@latest
)

log_section() {
  printf '\n==> %s\n' "$1"
}

require_command() {
  local command_name="$1"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    printf 'Error: required command not found: %s\n' "$command_name" >&2
    exit 1
  fi
}

print_prerequisites() {
  cat <<'EOF'
Prerequisites:
  1. Install Xcode Command Line Tools:
     xcode-select --install

  2. Install Homebrew:
     /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
EOF
}

configure_macos_defaults() {
  log_section "Configuring macOS defaults"

  # Disable press-and-hold so key repeat works consistently in editors.
  defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

  # Set keyboard repeat to the fastest supported defaults.
  defaults write -g InitialKeyRepeat -int 15
  defaults write -g KeyRepeat -int 2

  # Allow dragging a window by clicking anywhere on it.
  # Reference: https://mmazzarolo.com/blog/2022-04-16-drag-window-by-clicking-anywhere-on-macos/
  defaults write -g NSWindowShouldDragOnGesture -bool true

  cat <<'EOF'
To disable window dragging later, run:
  defaults delete -g NSWindowShouldDragOnGesture
EOF
}

install_homebrew_packages() {
  log_section "Installing Homebrew packages"
  require_command brew

  brew install "${BREW_PACKAGES[@]}"
}

install_go_tools() {
  log_section "Installing Go tools"
  require_command go

  local tool
  for tool in "${GO_TOOLS[@]}"; do
    go install "$tool"
  done
}

main() {
  print_prerequisites
  configure_macos_defaults
  install_homebrew_packages
  install_go_tools
}

main "$@"
